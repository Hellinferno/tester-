# ════════════════════════════════════════════════════════════════════
# SLM Router — Environment Variables
# Copy to `.env` and fill in. Never commit the real `.env`.
# Same keys are used by Render (per-service env) and Vercel (project env).
# ════════════════════════════════════════════════════════════════════

# ── Core / runtime ───────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug                      # debug | info | warn | error
APP_ENV=development                  # development | staging | production
# Comma-separated. Wildcards only allowed in development.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Supabase (Postgres + Auth + Storage) ─────────────────────────────
# Local: run `pnpm docker:up` then use these. Production: your hosted project.
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=                   # local anon key from `supabase status`
SUPABASE_SERVICE_ROLE_KEY=           # local service role key from `supabase status`
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Postgres direct connection (for migrations / scripts)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ── Upstash Redis (cache + job queue) ────────────────────────────────
# Local: provided by docker-compose. Production: Upstash REST or Redis URL.
REDIS_URL=redis://localhost:6379/0
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Service URLs (internal, on Render / local docker) ────────────────
ORCHESTRATOR_URL=http://localhost:8001
OCR_SERVICE_URL=http://localhost:8002
STT_SERVICE_URL=http://localhost:8003
ANALYSIS_ENGINE_URL=http://localhost:8004
ROUTER_SERVICE_URL=http://localhost:8005
# Shared secret for service-to-service auth ( Render internal calls )
SERVICE_AUTH_TOKEN=dev-only-change-me

# ── OpenRouter (SLM analysis + model routing + generation) ───────────
# BYOK: leave blank. Users supply their own key in the UI (Settings); it is sent
# per-request as the X-OpenRouter-Key header and never stored server-side.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# System SLM used for query analysis before routing (not the generation model)
ANALYSIS_SLM_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_TIMEOUT_MS=30000
OPENROUTER_MAX_RETRIES=3
# Optional: comma-separated keys for rotation
OPENROUTER_API_KEYS=

# ── Web app (Next.js) — exposed to the browser ───────────────────────
# Base URL the browser uses to reach the orchestrator (Render URL in prod).
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8001
# Default generation model. 'auto' = smart routing; or an OpenRouter model id.
NEXT_PUBLIC_DEFAULT_MODEL=auto

# ── Web-search grounding (SerpAPI) ───────────────────────────────────
# App-level key (not BYOK). Used by the orchestrator when a query enables
# "Web Search". Leave blank to disable grounding.
SERPAPI_API_KEY=

# ── Limits (from PRD FR-02/03/04) ────────────────────────────────────
MAX_IMAGE_SIZE_BYTES=20971520        # 20 MB
MAX_VOICE_DURATION_SECONDS=300       # 5 min
MAX_TEXT_LENGTH=32000
RATE_LIMIT_PER_MINUTE=100            # per user
RATE_LIMIT_API_KEY_PER_MINUTE=1000   # per API key

# ── Storage buckets ──────────────────────────────────────────────────
STORAGE_BUCKET_IMAGES=images
STORAGE_BUCKET_AUDIO=audio
